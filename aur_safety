#!/usr/bin/env python3
import argparse
import hashlib
import json
import os
import subprocess
import sys
import urllib.request
from pathlib import Path

CONFIG_DIR = Path.home() / ".config" / "aur_safety"
CONFIG_FILE = CONFIG_DIR / "config.json"
REPO_BASE = "https://raw.githubusercontent.com/signaldirective/aur_safety/main"
AUR_HELPERS = ["yay", "pacaur", "paru"]

LIST_FILES = [
    "package_list.txt",
    "chaos_rat_packages.txt",
    "malicious_npm_packages.txt",
    "malicious_russian_spam_packages.txt",
]

RED = "\033[91m"
GREEN = "\033[92m"
RESET = "\033[0m"


def load_config():
    if CONFIG_FILE.exists():
        with open(CONFIG_FILE) as f:
            return json.load(f)
    return {}


def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)
        f.write("\n")


def get_aur_helper():
    cfg = load_config()
    helper = cfg.get("aur_helper")
    if helper:
        return helper

    print("aur_safety needs to know which AUR helper you use.")
    for i, h in enumerate(AUR_HELPERS, 1):
        print(f"  [{i}] {h}")
    while True:
        try:
            choice = input(f"Enter 1-{len(AUR_HELPERS)}: ").strip()
            idx = int(choice) - 1
            if 0 <= idx < len(AUR_HELPERS):
                helper = AUR_HELPERS[idx]
                break
        except (ValueError, EOFError, KeyboardInterrupt):
            pass
        print("Invalid choice.")

    save_config({"aur_helper": helper})
    print(f"Using {helper}. Run `aur_safety config` to change it later.\n")
    return helper


def load_bad_packages():
    bad = set()
    for fname in LIST_FILES:
        p = CONFIG_DIR / fname
        if p.exists():
            with open(p) as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith("#"):
                        bad.add(line)
    return bad


def strip_aur_prefix(name):
    if name.startswith("aur/"):
        return name[4:]
    return name


def cmd_find(args, bad_packages):
    helper = get_aur_helper()
    search_args = [helper, "-Ss"] + args.query
    proc = subprocess.Popen(search_args, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True)

    for line in proc.stdout:
        stripped = line.rstrip("\n")
        if stripped.startswith("aur/"):
            pkgname = strip_aur_prefix(stripped.split()[0])
            if pkgname in bad_packages:
                print(f"{stripped} ({RED}unsafe{RESET})")
            else:
                print(stripped)
        else:
            print(stripped)

    proc.wait()
    sys.exit(proc.returncode)


def cmd_install(args, bad_packages):
    helper = get_aur_helper()
    for pkg in args.packages:
        if pkg in bad_packages:
            print(
                f"Package {pkg} is on a list of suspected packages that may be "
                f"infected with malware. Are you sure you wish to install this package? y/N",
                end=" ",
            )
            sys.stdout.flush()
            try:
                resp = input().strip().lower()
            except (EOFError, KeyboardInterrupt):
                resp = "n"
            if resp != "y":
                print("Cancelled.")
                sys.exit(1)

    cmd = [helper, "-S"] + args.packages + args.pass_args
    os.execvp(helper, cmd)


def _sha256(data):
    return hashlib.sha256(data).hexdigest()


def _download(url):
    try:
        with urllib.request.urlopen(url, timeout=15) as r:
            return r.read()
    except urllib.error.URLError as e:
        print(f"  Failed to download {url}: {e}", file=sys.stderr)
        return None


def cmd_update_lists(args, bad_packages):
    updated = False

    for fname in LIST_FILES:
        dst = CONFIG_DIR / fname
        url = f"{REPO_BASE}/{fname}"

        print(f"  Checking {fname}...", end=" ")
        remote_data = _download(url)
        if remote_data is None:
            print("SKIP")
            continue

        remote_hash = _sha256(remote_data)
        local_hash = _sha256(dst.read_bytes()) if dst.exists() else ""

        if remote_hash == local_hash:
            print("up to date")
        else:
            dst.write_bytes(remote_data)
            dst.chmod(0o644)
            print("updated")
            updated = True

    if updated:
        print("\nPackage lists updated. Run `aur_safety update-lists` again to verify.")
    else:
        print("\nAll lists are up to date.")


def cmd_config(args, bad_packages):
    cfg = load_config()
    current = cfg.get("aur_helper", "not set")

    if args.helper:
        if args.helper not in AUR_HELPERS:
            print(f"Invalid helper. Choose from: {', '.join(AUR_HELPERS)}")
            sys.exit(1)
        save_config({"aur_helper": args.helper})
        print(f"AUR helper set to {args.helper}.")
    else:
        print(f"Current AUR helper: {current}")
        print("Change it with:  aur_safety config <helper>")
        print(f"Valid helpers:    {', '.join(AUR_HELPERS)}")


def main():
    bad_packages = load_bad_packages()

    parser = argparse.ArgumentParser(
        description="Wrapper for yay/pacaur/paru that checks packages against known AUR malware lists"
    )
    sub = parser.add_subparsers(dest="command", required=True)

    find_p = sub.add_parser("find", help="Search AUR with safety annotations")
    find_p.add_argument("query", nargs=argparse.REMAINDER, help="Search terms")
    find_p.set_defaults(func=cmd_find)

    install_p = sub.add_parser("install", help="Install AUR packages with safety check")
    install_p.add_argument("packages", nargs="+", help="Package name(s) to install")
    install_p.add_argument("pass_args", nargs=argparse.REMAINDER, help="Extra args passed to the AUR helper")
    install_p.set_defaults(func=cmd_install)

    update_p = sub.add_parser("update-lists", help="Update package lists from GitHub")
    update_p.set_defaults(func=cmd_update_lists)

    config_p = sub.add_parser("config", help="View or change AUR helper configuration")
    config_p.add_argument("helper", nargs="?", choices=AUR_HELPERS, help="Set AUR helper")
    config_p.set_defaults(func=cmd_config)

    parsed = parser.parse_args()
    parsed.func(parsed, bad_packages)


if __name__ == "__main__":
    main()
